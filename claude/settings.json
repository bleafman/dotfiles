{
  "permissions": {
    "allow": [
      "Write(~/tmp/**)",
      "Edit(~/tmp/**)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(trash:*)",
      "Bash(osgrep:*)",
      "WebSearch"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "open-prose@prose": true,
    "design-and-refine@design-plugins": true
  },
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "~/.claude/hooks/command-validator.sh" }]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [{ "type": "command", "command": "~/.claude/hooks/session-to-markdown.sh" }]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "~/.claude/hooks/session-to-markdown.sh" }]
      }
    ]
  }
}
